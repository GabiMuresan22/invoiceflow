# PostgreSQL connection string (e.g. from Neon, Supabase, or Vercel Postgres)
DATABASE_URL="postgresql://user:password@host:5432/invoiceflow?sslmode=require"

# Direct connection URL (used by Prisma migrations — same as DATABASE_URL for most providers)
DIRECT_URL="postgresql://user:password@host:5432/invoiceflow?sslmode=require"
